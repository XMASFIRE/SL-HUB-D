repeat task.wait() until game:IsLoaded()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Stats = game:GetService("Stats")
local LocalPlayer = Players.LocalPlayer

if getgenv().SL_HUB_AFK then return end
getgenv().SL_HUB_AFK = true

local startTime = tick()

local Gui = Instance.new("ScreenGui", game.CoreGui)
Gui.Name = "SL_HUB_AFK"

local Main = Instance.new("Frame", Gui)
Main.Size = UDim2.new(0,220,0,160)
Main.Position = UDim2.new(0.8,0,0.12,0)
Main.BackgroundColor3 = Color3.fromRGB(15,15,15)
Main.BorderSizePixel = 0
Main.Active = true
Main.Draggable = true
Instance.new("UICorner", Main)

local Stroke = Instance.new("UIStroke", Main)
Stroke.Thickness = 1.5
local hue = 0
RunService.RenderStepped:Connect(function()
	hue = (hue + 0.003) % 1
	Stroke.Color = Color3.fromHSV(hue,1,1)
end)

local Top = Instance.new("Frame", Main)
Top.Size = UDim2.new(1,0,0,28)
Top.BackgroundColor3 = Color3.fromRGB(20,20,20)
Top.BorderSizePixel = 0
Instance.new("UICorner", Top)

local Title = Instance.new("TextLabel", Top)
Title.Size = UDim2.new(1,0,1,0)
Title.BackgroundTransparency = 1
Title.Text = "SL HUB | ANTI AFK"
Title.Font = Enum.Font.GothamBold
Title.TextSize = 12
Title.TextColor3 = Color3.fromRGB(255,255,255)

RunService.RenderStepped:Connect(function()
	Title.TextColor3 = Color3.fromHSV(hue,1,1)
end)

local function createStat(yPos, text)
	local label = Instance.new("TextLabel", Main)
	label.Size = UDim2.new(1,0,0,22)
	label.Position = UDim2.new(0,0,yPos,0)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.Gotham
	label.TextSize = 12
	label.TextColor3 = Color3.fromRGB(220,220,220)
	label.Text = text
	return label
end

local TimeLabel = createStat(0.3, "⏰Time: 00:00:00")
local FPSLabel  = createStat(0.5, "FPS: 0")
local PingLabel = createStat(0.7, "Ping: 0 ms")

spawn(function()
	while true do
		task.wait(1)
		local elapsed = math.floor(tick() - startTime)
		local hours = math.floor(elapsed/3600)
		local minutes = math.floor((elapsed % 3600)/60)
		local seconds = elapsed % 60
		TimeLabel.Text = string.format("Time: %02d:%02d:%02d", hours, minutes, seconds)

		local fps = math.floor(1/RunService.RenderStepped:Wait())
		FPSLabel.Text = "🚀FPS: "..fps

		local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
		PingLabel.Text = "📶Ping: "..ping.." ms"
	end
end)

LocalPlayer.Idled:Connect(function()
	local vu = game:GetService("VirtualUser")
	vu:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
	task.wait(1)
	vu:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)
